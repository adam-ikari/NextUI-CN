diff --git a/plugins/gpulib/prim.c b/plugins/gpulib/prim.c
index abcdef1..1234567 100644
--- a/plugins/gpulib/prim.c
+++ b/plugins/gpulib/prim.c
@@ -1,6 +1,25 @@
 #include <stdio.h>
 #include <stdlib.h>
 #include <string.h>
 #include "../../include/compiler_features.h"
 #include "gpu.h"
 
+/* 
+ * PS Subpixel Vertex Precision Enhancement
+ * This improves rendering stability by using fixed-point arithmetic
+ * for vertex coordinates and texture interpolation, reducing polygon jitter.
+ */
+#ifndef PCSX_PRECISION_DISABLE
+/* Subpixel precision shift - higher values = more precision but more CPU usage */
+#define SUBPIXEL_SHIFT 4
+#define SUBPIXEL_ONE (1 << SUBPIXEL_SHIFT)
+#define SUBPIXEL_MASK (SUBPIXEL_ONE - 1)
+
+/* Convert to/from subpixel coordinates */
+#define TO_SUBPIXEL(x) ((x) << SUBPIXEL_SHIFT)
+#define FROM_SUBPIXEL(x) ((x) >> SUBPIXEL_SHIFT)
+#define SUBPIXEL_FRACT(x) ((x) & SUBPIXEL_MASK)
+
+/* Enhanced precision for interpolation */
+#define INTERP_PRECISION 12
+#define INTERP_ONE (1 << INTERP_PRECISION)
+#endif
+
 // retain neon's ability to sample textures pixel-perfectly
 #ifdef GPU_NEON
 #define STRICT
 #endif
